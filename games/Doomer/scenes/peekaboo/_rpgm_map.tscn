[sub_resource type="GDScript" id="GDScript_txeor"]
script/source = "@tool
extends Control

@export_multiline var notes : String = \"\":
	set(value):
		if not Engine.is_editor_hint(): return
		notes = value
		(find_child(\"Label\") as Label).text = notes
		

func _ready():
	if not Engine.is_editor_hint():
		visible = false
"

