[sub_resource type="GDScript" id="GDScript_byr4j"]
script/source = "extends _RPGM_Script

signal returned_from_viewport_and_finished
@onready var _viewport = get_core().get_scene(\"_Scroller\") as _Scroller # load(\"res://scenes/swiper/_swiper.tscn\").instantiate() as _Swiper


# adjust _on_viewport_finished such that it takes in 
# the parameters returned from the connected _Core_Viewport
func _on_viewport_finished(selection):
	get_core().change_viewport(get_rpgm())
	await get_rpgm().activated
	
	await get_lambdas().show_messages([\"You selected %s.\" % selection])
	returned_from_viewport_and_finished.emit()


func _on_action_within_area():
	_viewport.finished.connect(_on_viewport_finished, CONNECT_ONE_SHOT)
	get_core().change_viewport(get_core().get_scene(\"_Scroller\"))
	await returned_from_viewport_and_finished
"

[sub_resource type="GDScript" id="GDScript_38inc"]
script/source = "extends _RPGM_Script

func _on_action_within_area():
	await get_lambdas().show_messages([\"Congratulation.\", \"You neither won or lost.\", \"You ended.\"])
	await get_tree().create_timer(.5).timeout
	get_tree().quit()
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_oaqr5"]
shader = ExtResource("17_txeor")

[sub_resource type="GDScript" id="GDScript_05s22"]
script/source = "extends _RPGM_Script

signal returned_from_viewport_and_finished
@onready var _viewport = get_core().get_scene(\"_Birds\") as _Birds # load(\"res://scenes/swiper/_swiper.tscn\").instantiate() as _Swiper


# adjust _on_viewport_finished such that it takes in 
# the parameters returned from the connected _Core_Viewport
func _on_viewport_finished():
	get_core().change_viewport(get_rpgm())
	await get_rpgm().activated
	
	await get_lambdas().show_messages([\"You neither won nor lost.\"])
	returned_from_viewport_and_finished.emit()


func _on_action():
	await get_mover().face(_get_direction_to_player())
	await get_lambdas().show_messages([\"This will start the Flying Birds Mario Party mini game.\"])
	await get_tree().create_timer(1).timeout
	
	_viewport.finished.connect(_on_viewport_finished, CONNECT_ONE_SHOT)
	get_core().change_viewport(get_core().get_scene(\"_Birds\"))
	await returned_from_viewport_and_finished
"

