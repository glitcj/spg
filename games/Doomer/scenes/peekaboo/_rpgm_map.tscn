[sub_resource type="GDScript" id="GDScript_jo6ms"]
script/source = "extends _RPGM_Event

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	super()
	get_core().get_log().add_log(func(): return str(active_scripts))
	get_core().get_log().add_log(func(): return \"state: %s\" % state)
"

[sub_resource type="GDScript" id="GDScript_uc14m"]
script/source = "extends _RPGM_Common_Script_Talker

func _is_active(): 
	return get_event().state == _RPGM_Event.EventState.A

func _on_action():
	await super()
	get_event().state = _RPGM_Event.EventState.B
	# get_event().update_active_scripts()
	# await get_tree().process_frame
	# get_event().update_active_scripts()
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vd6wf"]
shader = ExtResource("17_txeor")

[sub_resource type="GDScript" id="GDScript_kl3l0"]
script/source = "extends _RPGM_Common_Script_Talker

func _is_active(): 
	return get_event().state == _RPGM_Event.EventState.B

func _on_action():
	await super()
	get_event().state = _RPGM_Event.EventState.A
	# await get_tree().process_frame
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_6le0f"]
shader = ExtResource("17_txeor")

[sub_resource type="GDScript" id="GDScript_x2jho"]
script/source = "extends _RPGM_Script



func _on_action():
	await get_lambdas().show_messages([\"Wait here.\"])
	await get_tree().create_timer(1).timeout
	await get_event().get_mover().walk(Vector2i(-1, 0))
	await get_tree().create_timer(1).timeout
	await get_event().get_mover().walk(Vector2i(1, 0))
	await get_tree().create_timer(1).timeout
	await get_lambdas().show_messages([\"Okay you can go now.\"])
"

