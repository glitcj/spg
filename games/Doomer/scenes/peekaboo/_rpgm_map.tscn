[sub_resource type="GDScript" id="GDScript_6le0f"]
script/source = "@tool
extends Node

@export_tool_button(\"Run\") var callable : Callable = _run

func _run():
	print(\"Just ran..\")
	for event in  get_parent().find_children(\"*\"): # find_children(\"_RPGM_Portrait\"):
		if event.has_method(\"_editor_update\"):
			print(event)
			event._editor_update()
		continue
	
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass
"

